<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GovJobAutofill" parent="Theme.MaterialComponents.DayNight.DarkActionBar.Bridge">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
    </style>

    <!-- Custom button style that avoids backgroundTint crash -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BrowserButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:background">@color/primary</item>
    </style>
</resources>

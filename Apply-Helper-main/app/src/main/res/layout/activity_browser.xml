<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/primary"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:backgroundTint="@color/primary"
                android:text="◀"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btnForward"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:backgroundTint="@color/primary"
                android:text="▶"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:padding="0dp"/>

            <EditText
                android:id="@+id/etUrl"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="#33FFFFFF"
                android:textColor="@color/white"
                android:textColorHint="#99FFFFFF"
                android:hint="ঠিকানা লিখুন..."
                android:textSize="13sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:singleLine="true"/>

            <Button
                android:id="@+id/btnGo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:backgroundTint="@color/primary"
                android:text="→"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btnRefresh"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:backgroundTint="@color/primary"
                android:text="↻"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:padding="0dp"/>
        </LinearLayout>

        <!-- Progress Bar — invisible (not gone) to avoid layout jump -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progressTint="@color/accent"
            android:visibility="invisible"/>

        <!-- WebView -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Bottom Nav Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/primary"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnHome"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary"
                android:text="🏠"
                android:textSize="18sp"
                android:textColor="@color/white"/>

            <Button
                android:id="@+id/btnBookmarks"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary"
                android:text="📌"
                android:textSize="18sp"
                android:textColor="@color/white"/>

            <Button
                android:id="@+id/btnAddBookmark"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary"
                android:text="➕"
                android:textSize="18sp"
                android:textColor="@color/white"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Floating Fill Button — no anchor, manual gravity -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabFill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="72dp"
        android:text="🚀 Form পূরণ করুন"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="@color/primary"
        android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

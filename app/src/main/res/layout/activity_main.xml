<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F3DB; সরকারি চাকরি অটোফিল"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Browse করুন, Form পূরণ করুন — একটি অ্যাপেই"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Profile Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PROFILE" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvProfileStatus" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textSize="15sp" />
                    <TextView android:id="@+id/tvProfileName" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="2dp"
                        android:textColor="@color/text_secondary" android:textSize="13sp" android:visibility="gone" />
                    <Button android:id="@+id/btnEditProfile" android:layout_width="match_parent"
                        android:layout_height="48dp" android:layout_marginTop="14dp"
                        android:backgroundTint="@color/primary" android:text="&#x270F;&#xFE0F; প্রোফাইল এডিট করুন"
                        android:textColor="@color/white" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Main Action Buttons -->
            <Button android:id="@+id/btnOpenBrowser"
                android:layout_width="match_parent" android:layout_height="60dp"
                android:backgroundTint="@color/green"
                android:text="&#x1F310; Browser খুলুন"
                android:textColor="@color/white" android:textSize="17sp" android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <Button android:id="@+id/btnMediaVault"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:backgroundTint="#FF00796B"
                android:text="&#x1F4F7; Media Vault — ছবি ও সিগনেচার"
                android:textColor="@color/white" android:textSize="15sp"
                android:layout_marginBottom="16dp"/>

            <!-- Quick Sites -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#x26A1; দ্রুত যান" android:textColor="@color/primary"
                        android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <Button android:id="@+id/btnBpsc" android:layout_width="0dp" android:layout_height="44dp"
                            android:layout_weight="1" android:layout_marginEnd="8dp"
                            android:backgroundTint="#FF1565C0" android:text="&#x1F4CB; BPSC"
                            android:textColor="@color/white" android:textSize="13sp"/>
                        <Button android:id="@+id/btnTeletalk" android:layout_width="0dp" android:layout_height="44dp"
                            android:layout_weight="1" android:backgroundTint="#FF6A1B9A"
                            android:text="&#x1F4F1; Teletalk" android:textColor="@color/white" android:textSize="13sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <Button android:id="@+id/btnEjobs" android:layout_width="0dp" android:layout_height="44dp"
                            android:layout_weight="1" android:layout_marginEnd="8dp"
                            android:backgroundTint="#FF2E7D32" android:text="&#x1F1E7;&#x1F1E9; eJobs"
                            android:textColor="@color/white" android:textSize="13sp"/>
                        <Button android:id="@+id/btnBb" android:layout_width="0dp" android:layout_height="44dp"
                            android:layout_weight="1" android:backgroundTint="#FFE65100"
                            android:text="&#x1F3E6; BD Bank" android:textColor="@color/white" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- How to use -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="12dp" app:cardElevation="4dp" android:layout_marginBottom="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="কীভাবে কাজ করে" android:textColor="@color/primary"
                        android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="১. প্রোফাইল + ছবি/সিগনেচার সেভ করুন&#10;২. Browser খুলুন বা সাইটে ট্যাপ করুন&#10;৩. ফর্মে &#x1F680; বাটন দেখাবে&#10;৪. চাপলেই সব field পূরণ হয়ে যাবে!"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Banner Ad at bottom of main screen -->
    <LinearLayout
        android:id="@+id/adContainerMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"/>

</LinearLayout>

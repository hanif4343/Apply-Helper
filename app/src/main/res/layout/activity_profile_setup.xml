<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@color/primary"
                android:text="ফিরে যান"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvSetupTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="প্রোফাইল সেটআপ"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@color/green"
                android:text="সেভ করুন"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Media Vault Button -->
        <Button
            android:id="@+id/btnOpenMediaVault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@color/primary"
            android:text="📁 মিডিয়া ভল্ট ওপেন করুন"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Profile Label -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="এই প্রোফাইলের নাম (যেমন: নিজের প্রোফাইল, ভাইয়ের প্রোফাইল)"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:textColor="@color/text_primary"
                android:id="@+id/etProfileLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════
             SECTION: Basic Information (ব্যক্তিগত তথ্য)
             ══════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ব্যক্তিগত তথ্য" android:textStyle="bold" android:textSize="15sp"
            android:textColor="@color/primary" android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Applicant's Name (English)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etFullNameEn" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="আবেদনকারীর নাম (বাংলায়)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etFullNameBn" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Father's Name (English)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etFatherNameEn" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="পিতার নাম (বাংলায়)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etFatherNameBn" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Mother's Name (English)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etMotherNameEn" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="মাতার নাম (বাংলায়)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etMotherNameBn" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Date of Birth (DD/MM/YYYY)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etDob" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="date" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Nationality — website-এ dropdown: Bangladeshi -->
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nationality (যেমন: Bangladeshi)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etNationality" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Religion — dropdown: Islam | Hinduism | Buddhism | Christianity | Other -->
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Religion (Islam / Hinduism / Buddhism / Christianity / Other)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etReligion" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Gender — dropdown: Male | Female | Third Gender -->
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gender (Male / Female / Third Gender)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etGender" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- National ID — dropdown: Yes/No + number field -->
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="National ID আছে? (Yes / No)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etNidStatus" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="National ID Number" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etNid" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Birth Registration — dropdown: Yes/No + number -->
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Birth Registration আছে? (Yes / No)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etBirthRegStatus" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Birth Registration Number" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etBirthRegNo" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Passport — dropdown: Yes/No + number -->
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Passport আছে? (Yes / No)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPassportStatus" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Passport Number (প্রযোজ্য হলে)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPassport" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Marital Status — dropdown: Single | Married | Other + Spouse Name -->
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Marital Status (Single / Married / Other)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etMarital" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Spouse Name (English) — বিবাহিত হলে" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etSpouseNameEn" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="স্বামী/স্ত্রীর নাম (বাংলায়) — বিবাহিত হলে" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etSpouseNameBn" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Mobile Number" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etMobile" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Confirm Mobile Number" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etConfirmMobile" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Email" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Quota -->
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Quota (Not Applicable / Freedom Fighter / Ethnic Minority...)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etQuota" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Departmental Status -->
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Departmental Status (Not Applicable / Govt. Employee...)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etDepartmentalStatus" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="রক্তের গ্রুপ (যেমন: B+)" android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etBloodGroup" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════
             SECTION: Present Address (বর্তমান ঠিকানা)
             ══════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="বর্তমান ঠিকানা (Present Address)" android:textStyle="bold" android:textSize="15sp"
            android:textColor="@color/primary" android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Care Of" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etCareOf" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Village / Road / House / Flat" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPresentVillage" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Post Office" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPresentPostOffice" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="District (জেলা)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPresentDistrict" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Upazila / P.S. (উপজেলা)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPresentUpazila" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="বিভাগ (Division)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPresentDivision" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Post Code" android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPresentPostCode" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════
             SECTION: Permanent Address (স্থায়ী ঠিকানা)
             ══════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="স্থায়ী ঠিকানা (Permanent Address)" android:textStyle="bold" android:textSize="15sp"
            android:textColor="@color/primary" android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Care Of" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPermanentCareOf" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Village / Road / House / Flat" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPermanentVillage" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Post Office" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPermanentPostOffice" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="District (জেলা)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPermanentDistrict" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Upazila / P.S. (উপজেলা)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPermanentUpazila" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="বিভাগ (Division)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPermanentDivision" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Post Code" android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etPermanentPostCode" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════
             SECTION: JSC / সমমান
             ══════════════════════════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="JSC / সমমান (যদি প্রযোজ্য হয়)" android:textStyle="bold" android:textSize="15sp"
            android:textColor="@color/primary" android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Examination (JSC / JDC / Class Eight / Junior Scholarship...)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etJscExam" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Board (Dhaka / Rajshahi / Barishal...)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etJscBoard" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Roll No" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etJscRoll" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Result Type (GPA out of 5 / GPA out of 4 / Passed)" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etJscResultType" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="GPA / Result" android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText android:textColor="@color/text_primary" android:id="@+id/etJscGpa" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>


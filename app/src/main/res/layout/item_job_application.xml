<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <TextView android:id="@+id/tvJobTitle" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="14sp"
            android:textStyle="bold" android:textColor="@color/text_primary"/>

        <TextView android:id="@+id/tvOrganization" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="13sp"
            android:textColor="@color/primary" android:layout_marginTop="2dp"/>

        <TextView android:id="@+id/tvApplicationDate" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="12sp"
            android:textColor="@color/text_secondary" android:layout_marginTop="4dp"/>

        <TextView android:id="@+id/tvTrackingId" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="12sp"
            android:textColor="@color/text_secondary" android:layout_marginTop="2dp"/>

        <!-- Badges Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <TextView android:id="@+id/tvPaymentBadge" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvStatusBadge" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="12sp" android:textColor="@color/text_secondary" android:gravity="end"/>
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="10dp">
            <Button android:id="@+id/btnEditJob" android:layout_width="0dp" android:layout_height="36dp"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                android:background="@color/primary" android:text="Edit"
                android:textColor="@color/white" android:textSize="12sp"/>
            <Button android:id="@+id/btnGeneratePdf" android:layout_width="0dp" android:layout_height="36dp"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                android:background="#FF00796B" android:text="PDF"
                android:textColor="@color/white" android:textSize="12sp"/>
            <Button android:id="@+id/btnDeleteJob" android:layout_width="0dp" android:layout_height="36dp"
                android:layout_weight="1" android:background="#FFC62828"
                android:text="Delete" android:textColor="@color/white" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
